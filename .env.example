# =============================================================================
# Forge — Environment Variables Template (.env.example)
# =============================================================================
# Copy this file to .env.local and configure your keys.
# See docs/ENVIRONMENT.md for detailed setup instructions.
# =============================================================================

# Runtime Environment
ENVIRONMENT=development
DEBUG=True

# LLM Providers (Bring Your Own Key - BYOK)
# Anthropic (Default recommended provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional BYOK Provider Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Primary Relational & Vector Persistence (Supabase / Postgres)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_from_project_settings
ADMIN_EMAIL=admin@example.com

# Frontend (also set in frontend/.env.local for `npm run dev`)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Redis (Caching & Celery Broker)
# Use memory://local when Redis is not running (dev fallback after ping failure)
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN=your_upstash_redis_token_if_using_upstash

# Code Execution Sandbox (e2b)
E2B_API_KEY=your_e2b_api_key_here

# Observability & Analytics (Optional)
SENTRY_DSN=your_sentry_dsn_here
POSTHOG_API_KEY=your_posthog_api_key_here
OPIK_API_KEY=your_opik_api_key_here
GROWTHBOOK_API_KEY=your_growthbook_api_key_here
